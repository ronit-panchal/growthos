# Copy to `.env.local` and fill values. Never commit secrets.

# Postgres (production: Supabase connection string or managed Postgres)
DATABASE_URL=

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Supabase Auth (NEXT_PUBLIC_* are exposed to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: server-only elevated access if you add Supabase Admin flows
SUPABASE_SERVICE_ROLE_KEY=

# Optional Razorpay — omit until you are ready to charge
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Optional SMTP — required for invoice/invite emails once you enable them
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
