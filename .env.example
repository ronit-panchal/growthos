# Copy to `.env.local` and fill values. Never commit secrets.
#
# QUICK START:
# 1. Get DATABASE_URL from Supabase -> Settings -> Database
# 2. Generate NEXTAUTH_SECRET: openssl rand -hex 32
# 3. Get Supabase keys from Supabase -> Settings -> API
# 4. Optional: Add OPENAI_API_KEY from https://platform.openai.com/api-keys
# 5. Optional: Set up SMTP for email notifications
#
# For Vercel: Add all these to your project's Environment Variables in dashboard

# ============================================================================
# REQUIRED - Database (PostgreSQL)
# ============================================================================
# For Supabase local development, prefer the Connection Pooling URL if your
# network does not support IPv6 well. The direct `db.<project-ref>.supabase.co`
# host often fails on IPv4-only localhost setups.
DATABASE_URL=

# ============================================================================
# REQUIRED - Authentication URLs & Secret
# ============================================================================
# For localhost development:
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# For production, change to your Vercel URL:
# NEXT_PUBLIC_APP_URL=https://your-app-name.vercel.app
# NEXTAUTH_URL=https://your-app-name.vercel.app

# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=

# ============================================================================
# REQUIRED - Supabase Authentication
# ============================================================================
# Get from: Supabase -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# OPTIONAL - AI Features (Audits, Proposals, Outreach)
# ============================================================================
# Get from: https://platform.openai.com/api-keys
# Without this, features work with mock data
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ============================================================================
# OPTIONAL - Email Notifications (SMTP)
# ============================================================================
# Gmail setup:
# 1. Enable 2-factor authentication
# 2. Create app password: https://myaccount.google.com/apppasswords
# 3. Use app password here (NOT your account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=GrowthOS <noreply@yourdomain.com>

# ============================================================================
# OPTIONAL - Payments (Razorpay)
# ============================================================================
# Get from: https://dashboard.razorpay.com/app/keys
# Leave empty until you're ready to add payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
