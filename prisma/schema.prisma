generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  avatar        String?
  role          String    @default("agency_owner") // agency_owner, team_member, admin
  status        String    @default("active") // active, disabled
  company       String?
  plan          String    @default("free") // free, starter, pro, enterprise
  trialEndsAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  managedById   String?

  accounts      Account[]
  sessions      Session[]
  leads         Lead[]
  audits        AuditJob[]
  outreach      OutreachCampaign[]
  proposals     Proposal[]
  activities    Activity[]
  authEvents    AuthEvent[]
  managedBy     User?     @relation("ManagedUsers", fields: [managedById], references: [id])
  managedUsers  User[]    @relation("ManagedUsers")

  @@index([managedById])
  @@index([role])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Lead {
  id            String    @id @default(cuid())
  name          String
  email         String
  phone         String?
  company       String?
  title         String?
  source        String    @default("manual") // manual, website, referral, linkedin, cold, event
  status        String    @default("new") // new, contacted, qualified, proposal, negotiation, won, lost
  score         Int       @default(0)
  value         Float     @default(0)
  tags          String?   // JSON string of tags array
  notes         String?   // JSON string of notes array @db.Text
  website       String?
  linkedin      String?
  lastContactAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId        String
  user          User      @relation(fields: [userId], references: [id])
  activities    Activity[]

  @@index([userId, createdAt])
}

model AuditJob {
  id            String    @id @default(cuid())
  url           String
  status        String    @default("pending") // pending, running, completed, failed
  progress      Int       @default(0)
  overallScore  Int?
  seoScore      Int?
  uxScore       Int?
  performance   Int?
  accessibility Int?
  findings      String?   // JSON string of findings array @db.Text
  suggestions   String?   // JSON string of suggestions array @db.Text
  error         String?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model OutreachCampaign {
  id            String    @id @default(cuid())
  name          String
  type          String    @default("cold_email") // cold_email, follow_up, linkedin, custom
  tone          String    @default("professional") // professional, casual, friendly, assertive
  industry      String?
  targetAudience String?
  subjectLine   String?
  content       String?
  cta           String?
  sequence      String?   // JSON string of sequence steps @db.Text
  status        String    @default("draft") // draft, active, completed
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model Proposal {
  id            String    @id @default(cuid())
  title         String
  clientName    String
  clientEmail   String?
  status        String    @default("draft") // draft, sent, viewed, accepted, rejected
  sections      String?   // JSON string of proposal sections @db.Text
  pricing       String?   // JSON string of pricing items @db.Text
  totalValue    Float     @default(0)
  shareToken    String?   @unique
  notes         String?
  sentAt        DateTime?
  viewedAt      DateTime?
  acceptedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model Activity {
  id            String    @id @default(cuid())
  type          String    // lead_created, audit_completed, outreach_sent, proposal_sent, etc.
  title         String
  description   String?
  metadata      String?   // JSON string of additional data @db.Text
  createdAt     DateTime  @default(now())

  userId        String
  user          User      @relation(fields: [userId], references: [id])
  leadId        String?
  lead          Lead?     @relation(fields: [leadId], references: [id])

  @@index([userId, createdAt])
}

model Subscription {
  id            String    @id @default(cuid())
  userId        String    @unique
  plan          String    @default("free")
  status        String    @default("active") // active, canceled, past_due, trialing
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)
  razorpaySubscriptionId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model AuthEvent {
  id           String   @id @default(cuid())
  eventType    String   // login, logout
  actorRole    String?
  actorEmail   String?
  ipAddress    String?
  userAgent    String?
  metadata     String?  @db.Text
  occurredAt   DateTime @default(now())

  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
  @@index([eventType, occurredAt])
}

